generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id                  String   @id @default(cuid())
  ticketNumber        String?
  title               String
  description         String?
  type                String
  category            String
  assignedTo          String
  status              String
  remark              String?
  creationDate        DateTime?
  startDate           DateTime?
  endDate             DateTime?
  additionalAssignees String[]
  createdAt           DateTime @default(now())
}