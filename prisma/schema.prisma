generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id                  String    @id @default(cuid())
  ticketNumber        String?
  title               String
  description         String?
  type                String
  category            String
  assignedTo          String
  status              String
  remark              String?

  creationDate        DateTime?
  startDate           DateTime?
  endDate             DateTime?
  completedDate       String?

  additionalAssignees String[]

  statusHistory       Json?
  updates             Json?
  beforePhotos        Json?
  afterPhotos         Json?
  estimation          Json?

  createdAt           DateTime  @default(now())
}